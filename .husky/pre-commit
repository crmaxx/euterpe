#!/usr/bin/env sh
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

if ! git diff --cached --name-only | grep -qE '^(frontend/|openapi/)'; then
  exit 0
fi

cd frontend
if [ ! -d node_modules ]; then
  echo "pre-commit: run 'cd frontend && npm ci' first" >&2
  exit 1
fi

npm run generate:api
npm run lint

# Server
EUTERPE_BIND=127.0.0.1:8080
# Public origin for OAuth callback (Settings → Connect Qobuz)
EUTERPE_PUBLIC_BASE_URL=http://127.0.0.1:8080

# Encrypt Qobuz UAT in SQLite (32 bytes, hex or base64). Required for OAuth link.
EUTERPE_MASTER_KEY=

# Verbose HTTP + Qobuz API debug logs (also: RUST_LOG=euterpe_server=debug,euterpe_qobuz=debug)
# EUTERPE_DEV=true

# Parent directory must exist OR use default (~/.local/share/euterpe/) which is auto-created.
# Docker: sqlite:/data/library.db?mode=rwc  (with /data volume mounted)
# EUTERPE_DATABASE_URL=sqlite:./data/library.db?mode=rwc

# Library root for downloads (created on startup if missing). Default: /music
# EUTERPE_LIBRARY_PATH=/music

# Parallel CDN HTTP downloads per album job. Default: 3
# EUTERPE_DOWNLOAD_CONCURRENCY=3

# Optional homelab admin auth on /api/v1/*
# EUTERPE_ADMIN_PASSWORD=
